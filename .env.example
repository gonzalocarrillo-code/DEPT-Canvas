# CE.SDK headless license (server-side only; never a tool argument)
CESDK_LICENSE=

# OpenAI API key (MCP server only; Secret Manager in production)
OPENAI_API_KEY=

# Self-hosted CE.SDK asset bundle URL (fonts/emoji); pin to @cesdk/node version
IMGLY_LOCAL_ASSETS_URL=

# Optional: override @cesdk/node version pin for spikes
CESDK_NODE_VERSION=1.76.1
